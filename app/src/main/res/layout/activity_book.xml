<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D2A679"
    tools:context=".MainActivity5">

    <!-- Назад кнопка -->
    <ImageButton
        android:id="@+id/back_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_margin="10dp"
        android:background="?attr/selectableItemBackground"
        android:src="@drawable/ic_back"
         />

    <!-- Обложка книги -->
    <ImageView
        android:id="@+id/book_cover"
        android:layout_width="200dp"
        android:layout_height="300dp"
        android:layout_below="@id/back_button"
        android:layout_centerHorizontal="true"
        android:src="@drawable/harry_potter"
        android:layout_marginTop="20dp" />

    <!-- Рейтинг -->
    <TextView
        android:id="@+id/rating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@id/book_cover"
        android:layout_toEndOf="@id/book_cover"
        android:layout_marginStart="10dp"
        android:text="4.5★"
        android:textColor="@color/black"
        android:textSize="18sp"
        android:padding="5dp" />

    <!-- Кнопка "Избранное" -->
    <ImageButton
        android:id="@+id/favorite_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/rating"
        android:layout_toEndOf="@id/book_cover"
        android:layout_marginStart="10dp"
        android:background="?attr/selectableItemBackground"
        android:src="@drawable/ic_favorite"
         />

    <!-- Название книги -->
    <TextView
        android:id="@+id/book_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/book_cover"
        android:layout_centerHorizontal="true"
        android:text="Гарри Поттер и узник Азкабана"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="10dp" />

    <!-- Автор книги -->
    <TextView
        android:id="@+id/book_author"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/book_title"
        android:layout_centerHorizontal="true"
        android:text="Дж. Роулинг"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:layout_marginTop="5dp" />


    <Button
        android:id="@+id/buy_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/book_author"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="15dp"
        android:text="Купить за 1500 рублей"
        android:textColor="@android:color/white" />

    <!-- Ссылка "Другие способы оплаты" -->
    <TextView
        android:id="@+id/payment_options"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/buy_button"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="5dp"
        android:text="Обратная связь"
        android:textSize="14sp" />

    <!-- Вкладка  Написать отзыв" -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="77dp"
        android:layout_below="@id/payment_options"
        android:layout_marginTop="11dp"
        android:orientation="horizontal"
        android:weightSum="2">

        <Button
            android:id="@+id/opinion_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/book_author"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="15dp"
            android:text="Напишите отзыв"
            android:textColor="@android:color/white" />

    </LinearLayout>



    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/payment_options"
        android:layout_marginTop="97dp"
        android:background="@color/white"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Оцените книгу"
            android:layout_centerHorizontal="true"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="5dp"
                android:src="@drawable/ic_star" />

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="5dp"
                android:src="@drawable/ic_star" />

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="5dp"
                android:src="@drawable/ic_star" />

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="5dp"
                android:src="@drawable/ic_star" />

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="30dp"
                android:src="@drawable/ic_star" />
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/about_book_tab"
        android:layout_width="0dp"
        android:layout_height="65dp"
        android:layout_weight="1"
        android:text="О книге"
        android:textColor="@android:color/white" />


</RelativeLayout>
